# Fynly Demo Configuration

# Mock Mode (all external integrations are simulated)
MOCK_MODE=true

# API Configuration
NEXT_PUBLIC_API_BASE=http://localhost:3001/api

# Demo Settings
NEXT_PUBLIC_DEMO_INVESTOR_COUNT=200
NEXT_PUBLIC_DEMO_ADVISOR_COUNT=50

# Timezone (for booking availability)
TZ=Asia/Kolkata

# Currency
NEXT_PUBLIC_CURRENCY=INR

# Video Simulation
NEXT_PUBLIC_VIDEO_SIMULATION=true
NEXT_PUBLIC_VIDEO_PROVIDER=daily_co_simulated

# Payment Simulation
NEXT_PUBLIC_PAYMENT_SIMULATION=true
NEXT_PUBLIC_PAYMENT_PROVIDER=razorpay_simulated

